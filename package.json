{
  "name": "manor",
  "private": true,
  "version": "0.5.3",
  "packageManager": "pnpm@10.23.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/patch-electron-name.mjs && vite",
    "build": "vite build",
    "preview": "vite preview",
    "package": "source .env && vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "electron-rebuild",
    "kill": "test -f ~/.manor/daemon/terminal-host.pid && kill $(cat ~/.manor/daemon/terminal-host.pid) 2>/dev/null; rm -f ~/.manor/daemon/terminal-host.pid ~/.manor/daemon/terminal-host.sock ~/.manor/daemon/terminal-host.token",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@electron/osx-sign": "^2.3.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.91.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.3.4",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.0.0",
    "portless": "^0.7.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "refractor": "^5.0.0",
    "tree-kill": "^1.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.0.4",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.manor.app",
    "productName": "Manor",
    "publish": {
      "provider": "github"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "extendInfo": {
        "NSUserNotificationAlertStyle": "alert"
      }
    },
    "files": [
      "dist/**/*",
      "!dist/mac-arm64",
      "!dist/builder-effective-config.yaml",
      "dist-electron/**/*"
    ],
    "asarUnpack": [
      "dist-electron/mcp-webview-server.js"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty",
      "electron",
      "esbuild"
    ]
  }
}
